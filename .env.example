# HackPit — environment config template.
# Copy this file to `.env` (which is gitignored) and fill in your values.
# NEVER commit a real .env or any secrets.

# --- LLM provider API keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# --- Local model runtime ---
# Base URL for a local Ollama server (e.g. http://localhost:11434)
OLLAMA_BASE_URL=
