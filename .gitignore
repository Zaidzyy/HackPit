# ---- HackPit root .gitignore ----
# This will be a PUBLIC repo: ship CODE ONLY.
# No third-party content, no raw notes, no secrets — ever.

# Knowledge (NEVER commit)
/data/
/sources/

# Secrets & env
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
*.secret

# LLM provider config — may hold an API key. NEVER commit.
llm_config.json
backend/llm_config.json

# Local engagement sessions store (SQLite). NEVER commit.
sessions.db
backend/sessions.db
*.db-wal
*.db-shm

# --- Node / Next.js (frontend) ---
node_modules/
.next/
out/
build/
dist/
.vercel/
*.tsbuildinfo
next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python (backend / pipeline) ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.python-version

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
